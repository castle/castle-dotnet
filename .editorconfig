root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{cs,csx}]
indent_size = 4
dotnet_sort_system_directives_first = true

[*.{csproj,props,targets,xml,config,yml,yaml,json}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
